<?xml version="1.0" encoding="utf-8" ?>
<extension type="component" method="upgrade">
	<name>com_pluggen</name>
	<creationDate>14-5-2026</creationDate>
	<author>Herman Peeren</author>
	<authorEmail>herman@yepr.nl</authorEmail>
	<authorUrl>https://yepr.nl</authorUrl>
	<copyright>Yepr, Herman Peeren, 2026</copyright>
	<license>GNU General Public License version 3 or later;</license>
	<version>0.0.2</version>
	<description>COM_PLUGGEN_XML_DESCRIPTION</description>
	<namespace path="src">Yepr\Component\Pluggen</namespace>
	<scriptfile>script.php</scriptfile>
	<install> <!-- Runs on install -->
		<sql>
			<file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
		</sql>
	</install>
	<uninstall> <!-- Runs on uninstall -->
		<sql>
			<file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
		</sql>
	</uninstall>
	<update>  <!-- Runs on update -->
		<schemas>
			<schemapath type="mysql">sql/updates/mysql</schemapath>
		</schemas>
	</update>
	<!-- Front-end files. No component-frontend, only media. -->
	<media folder="media/com_pluggen" destination="com_pluggen">
		<folder>js</folder>
	</media>
	<!-- Back-end files -->
	<administration>
		<!-- Menu entries -->
		<menu view="pluggen">COM_PLUGGEN</menu>
		<submenu>
			<menu link="option=com_pluggen&amp;view=projects">COM_PLUGGEN_SUBMENU_MANAGER_PROJECTS</menu>
			<menu link="option=com_pluggen&amp;view=generators">COM_PLUGGEN_SUBMENU_MANAGER_GENERATORS</menu>
			<menu link="option=com_pluggen&amp;view=info">COM_PLUGGEN_SUBMENU_MANAGER_INFO</menu>
		</submenu>
		<files folder="administrator/components/com_pluggen">
			<filename>access.xml</filename>
			<filename>config.xml</filename>
			<folder>forms</folder>
			<folder>generator_templates</folder>
			<folder>language</folder>
			<folder>services</folder>
			<folder>sql</folder>
			<folder>src</folder>
			<folder>tmpl</folder>
		</files>
		<languages folder="administrator/components/com_pluggen">
			<language tag="en-GB">language/en-GB/com_pluggen.ini</language>
			<language tag="en-GB">language/en-GB/com_pluggen.sys.ini</language>
		</languages>
	</administration>
	<changelogurl>https://raw.githubusercontent.com/hermanpeeren/pluggen/changelog.xml</changelogurl>
	<updateservers>
		<server type="extension" name="Plugin Generator Updates">https://github.com/HermanPeeren/Pluggen/raw/refs/heads/main/pluggen_update.xml</server>
	</updateservers>
</extension>
