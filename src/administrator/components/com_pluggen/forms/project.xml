<?xml version="1.0" encoding="utf-8"?>
<form>
	<fieldset
		addruleprefix="Yepr\Component\Pluggen\Administrator\Rule"
		addfieldprefix="Yepr\Component\Pluggen\Administrator\Field"
	>
		<field
			name="plugin_name"
			type="text"
			label="Plugin name"
			size="40"
			required="true"
			class="pluginName"
		/>

		<field
			name="plugin_type"
			type="plugintypes"
			default="task"
			label="Plugin type"
			size="40"
			required="true"
		/>
		<field
			name="plugin_description"
			type="editor"
			label="Plugin description"
		/>

		<field
			name="manifest"
			type="subform"
			formsource="administrator/components/com_pluggen/forms/manifest.xml"
			multiple="false"
			min="1"
			label="Manifest"
			id="manifest"
			layout="joomla.form.field.subform.default"
		/>

		<field
			name="languages"
			type="subform"
			formsource="administrator/components/com_pluggen/forms/language.xml"
			multiple="true"
			min="1"
			label="Languages"
			id="languages"
			layout="joomla.form.field.subform.repeatable"
		/>

	</fieldset>

	<fieldset name="general"
			  addruleprefix="Yepr\Component\Pluggen\Administrator\Rule"
			  addfieldprefix="Yepr\Component\Pluggen\Administrator\Field"
	>
		<field
				name="id"
				type="number"
				label="JGLOBAL_FIELD_ID_LABEL"
				default="0"
				class="readonly"
				readonly="true"
		/>

		<field
				name="state"
				type="list"
				label="JSTATUS"
				default="1"
				id="published"
				class="custom-select-color-state"
				size="1"
		>
			<option value="1">JPUBLISHED</option>
			<option value="0">JUNPUBLISHED</option>
			<option value="2">JARCHIVED</option>
			<option value="-2">JTRASHED</option>
		</field>

		<field
				name="access"
				type="accesslevel"
				label="JFIELD_ACCESS_LABEL"
				size="1"
		/>

		<field
				name="checked_out"
				type="hidden"
				filter="unset"
		/>

		<field
				name="checked_out_time"
				type="hidden"
				filter="unset"
		/>

		<field
				name="ordering"
				type="ordering"
				label="JFIELD_ORDERING_LABEL"
				content_type="COM_PLUGGEN.pluggen"
		/>

		<field
				name="project_id"
				type="hidden"
		/>
	</fieldset>
</form>
